    "site": {
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "description": "Adapter selection mode.",
          "type": "string"
        },
        "canonical_style": {
          "description": "Preferred internal canonical style.",
          "type": "string"
        },
        "source_dir": {
