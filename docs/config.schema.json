    {
      "if": {
        "anyOf": [
          {
            "required": [
              "site"
            ]
          },
          {
            "required": [
              "runtime"
            ]
          },
          {
            "required": [
              "policy"
            ]
          },
          {
            "required": [
              "rules"
            ]
          },
          {
            "required": [
              "output"
            ]
          },
          {
            "required": [
              "quality"
            ]
          }
        ]
      },
      "then": {
        "properties": {
          "version": {
            "const": 1
          }
        },
        "required": [
          "version"
        ]
      }
    }
  ],
  "properties": {
    "adapter": {
      "description": "Adapter selection mode.",
      "type": "string"
    },
    "audit_log_limit": {
      "description": "Number of audit artifacts retained per command.",
      "minimum": 0,
      "type": "integer"
    },
    "baseline_file": {
      "description": "Default audit baseline path.",
      "type": "string"
    },
    "browser_engine": {
      "description": "Default crawl engine.",
      "type": "string"
    },
    "browser_wait_until": {
      "description": "Browser navigation wait strategy.",
      "type": "string"
    },
    "cache_dir": {
      "description": "Directory for persistent caches.",
      "type": "string"
    },
    "cache_ttl_seconds": {
      "description": "Maximum age for reusable crawl cache entries.",
      "minimum": 0,
      "type": "integer"
    },
    "canonical_style": {
      "description": "Preferred internal canonical style.",
      "type": "string"
    },
    "checks": {
      "additionalProperties": {
        "type": "boolean"
      },
      "description": "Built-in rule-group toggles.",
      "type": "object"
    },
    "complexity_threshold": {
      "description": "Maximum allowed complexity threshold.",
      "minimum": 0,
      "type": "integer"
    },
    "coverage_threshold": {
      "description": "Minimum coverage percentage expected by quality checks.",
      "minimum": 0,
      "type": "integer"
    },
    "crawl_artifact_dir": {
      "description": "Directory used for crawl artifacts.",
      "type": "string"
    },
    "crawl_basic_auth": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Basic auth credentials for runtime crawl sessions.",
      "type": "object"
    },
    "crawl_capture_console": {
      "description": "Whether browser crawl should persist console output.",
      "type": "boolean"
    },
    "crawl_capture_network": {
      "description": "Whether browser crawl should persist network logs.",
      "type": "boolean"
    },
    "crawl_capture_screenshot": {
      "description": "Whether browser crawl should save screenshots.",
      "type": "boolean"
    },
    "crawl_capture_trace": {
      "description": "Whether browser crawl should capture a trace artifact.",
      "type": "boolean"
    },
    "crawl_cookies": {
      "description": "Cookies injected into runtime crawl sessions.",
