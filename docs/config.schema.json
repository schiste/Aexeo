      "description": "Whether nested pages must emit BreadcrumbList schema.",
      "type": "boolean"
    },
    "require_fact_consistency": {
      "description": "Whether visible and structured page facts should align.",
      "type": "boolean"
    },
    "require_hreflang_self": {
      "description": "Whether pages with hreflang alternates require a self-reference.",
      "type": "boolean"
    },
    "require_html_lang": {
      "description": "Whether indexable pages must declare html lang.",
      "type": "boolean"
    },
    "require_meta_robots_consistency": {
      "description": "Whether sitemap/indexability robots inconsistencies should be flagged.",
      "type": "boolean"
    },
    "require_open_graph": {
      "description": "Whether core Open Graph tags are required.",
      "type": "boolean"
    },
    "require_robots_sitemap": {
      "description": "Whether robots.txt must declare a sitemap.",
      "type": "boolean"
