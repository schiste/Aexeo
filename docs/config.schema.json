    "require_social_images": {
      "description": "Whether og:image is required.",
      "type": "boolean"
    },
    "require_twitter_card": {
      "description": "Whether twitter:card is required.",
      "type": "boolean"
    },
    "require_twitter_image": {
      "description": "Whether twitter:image is required.",
      "type": "boolean"
    },
    "required_feature_markers": {
      "description": "Literal strings required on feature-like pages.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "required_schema_families": {
      "description": "Schema families that should be validated.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "required_schema_types": {
      "description": "JSON-LD @type values expected on route pages.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "route_policy_overrides": {
      "description": "Per-route robots policy overrides.",
      "items": {
        "additionalProperties": false,
        "properties": {
          "allow_canonical_noindex": {
            "type": "boolean"
          },
          "allow_nofollow": {
            "type": "boolean"
          },
          "pattern": {
            "type": "string"
          }
