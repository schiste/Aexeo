    "min_block_text_length": {
      "description": "Minimum visible text length for a semantic content block.",
      "minimum": 0,
      "type": "integer"
    },
    "min_inbound_links": {
      "description": "Minimum inbound internal links before LNK004 triggers.",
      "minimum": 0,
      "type": "integer"
    },
    "min_page_size": {
      "description": "Minimum visible text length before CNT001 triggers.",
      "minimum": 0,
      "type": "integer"
    },
    "orphan_exclude": {
      "description": "Routes or filenames excluded from orphan detection.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "output": {
      "additionalProperties": false,
      "properties": {
        "audit_log_limit": {
          "minimum": 0,
          "type": "integer"
        },
        "baseline_file": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "performance_budget_file": {
      "description": "Performance budget file checked by repo quality.",
      "type": "string"
    },
    "plugin_settings": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "description": "Plugin-specific settings keyed by plugin namespace. Use quoted TOML tables such as `[plugin_settings.\"example.plugin\"]`. Each namespace must also appear in `plugins`, and only registered plugin settings schemas are accepted.",
      "type": "object"
    },
    "plugins": {
      "description": "Plugins that extend rules or adapters.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "policy": {
      "additionalProperties": false,
      "properties": {
        "ignore_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ignore_rules": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "route_policy_overrides": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "allow_canonical_noindex": {
                "type": "boolean"
              },
              "allow_nofollow": {
                "type": "boolean"
              },
              "pattern": {
                "type": "string"
              }
            },
            "required": [
              "pattern"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "severity_overrides": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
