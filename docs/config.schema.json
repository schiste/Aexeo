              "path_pattern": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "rule_id": {
                "type": "string"
              }
            },
            "required": [
              "rule_id",
              "path_pattern",
              "reason"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
