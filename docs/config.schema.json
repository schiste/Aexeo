                "require_breadcrumb_schema": {
                  "type": "boolean"
                },
                "require_title_alignment": {
                  "type": "boolean"
                },
                "required_families": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "required_types": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            }
          ]
        },
        "sitemap": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                }
              },
              "type": "object"
            }
          ]
        },
        "social": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "additionalProperties": false,
              "properties": {
                "default_twitter_card": {
                  "type": "string"
                },
                "enabled": {
                  "type": "boolean"
                },
                "require_open_graph": {
                  "type": "boolean"
                },
                "require_social_images": {
                  "type": "boolean"
                },
                "require_twitter_card": {
                  "type": "boolean"
                },
                "require_twitter_image": {
                  "type": "boolean"
                }
              },
              "type": "object"
            }
          ]
        },
        "structure": {
          "oneOf": [
            {
              "type": "boolean"
