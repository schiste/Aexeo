            {
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "min_answer_blocks": {
                  "minimum": 0,
                  "type": "integer"
                },
                "min_block_text_length": {
                  "minimum": 0,
                  "type": "integer"
                },
                "repeatable_data_ui": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "require_fact_consistency": {
                  "type": "boolean"
                },
                "utility_route_patterns": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            }
