        "additionalProperties": {
          "type": "string"
        },
        "type": "object"
      },
      "type": "array"
    },
    "crawl_exclude_patterns": {
      "description": "Route substrings excluded from runtime crawl.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "crawl_headers": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Extra HTTP headers applied to runtime crawl requests.",
      "type": "object"
    },
    "crawl_include_patterns": {
      "description": "Route substrings used to constrain runtime crawl scope.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "crawl_seeds": {
      "description": "Additional route seeds for runtime crawl.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "crawl_use_sitemap": {
      "description": "Whether runtime crawl should seed routes from sitemap.xml.",
      "type": "boolean"
    },
    "default_twitter_card": {
      "description": "Default twitter:card value used by safe fixes.",
      "type": "string"
    },
    "enable_cache": {
      "description": "Whether persistent caches may be used.",
      "type": "boolean"
    },
    "enable_link_autofix": {
      "description": "Whether safe fix mode may insert related-links sections.",
      "type": "boolean"
    },
    "extends": {
      "description": "Parent config file or files merged before the current config.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      ]
    },
    "ignore_paths": {
      "description": "Path patterns to suppress after evaluation.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "ignore_rules": {
      "description": "Rule IDs to suppress after evaluation.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "link_suggestion_count": {
      "description": "Candidate internal-link suggestions per weakly linked page.",
      "minimum": 0,
      "type": "integer"
    },
    "max_workers": {
      "description": "Worker count used for parallel analysis tasks.",
      "minimum": 0,
      "type": "integer"
    },
    "min_answer_blocks": {
      "description": "Minimum answer-oriented blocks required for a page.",
      "minimum": 0,
      "type": "integer"
