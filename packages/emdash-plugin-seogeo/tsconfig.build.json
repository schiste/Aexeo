{
  // Build-only tsconfig. tsc emits .js + .d.ts for everything under src/
  // EXCEPT sandbox-entry.ts — that file is bundled by esbuild
  // (scripts/build-bundle.mjs) into a single self-contained module
  // because emdash's Worker Loader can't resolve relative imports
  // between plugin files at runtime. Without this exclusion, tsc
  // emits an unbundled dist/sandbox-entry.js whose `./mcp.js` etc.
  // imports would crash the isolate at startup.
  //
  // The default tsconfig.json (used by `npm run typecheck`) includes
  // sandbox-entry.ts so type errors there are still caught.
  "extends": "./tsconfig.json",
  "exclude": ["node_modules", "dist", "wasm", "src/sandbox-entry.ts"]
}
