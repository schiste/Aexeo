{
  "name": "@aexeo/emdash-plugin-seogeo",
  "version": "0.0.1",
  "private": true,
  "description": "Aexeo seogeo rules as an emdash plugin",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "files": [
    "dist",
    "wasm",
    "scripts/build-wasm.sh"
  ],
  "scripts": {
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run build:ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@emdash-cms/core": "*"
  },
  "peerDependenciesMeta": {
    "@emdash-cms/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
