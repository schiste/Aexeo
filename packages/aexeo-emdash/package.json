{
  "name": "@aeptus/aexeo-emdash",
  "version": "0.8.6",
  "description": "Aexeo SEO/GEO content evaluator as an emdash plugin",
  "license": "MIT",
  "author": "Aeptus",
  "homepage": "https://github.com/schiste/Aexeo/tree/main/packages/aexeo-emdash",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schiste/Aexeo.git",
    "directory": "packages/aexeo-emdash"
  },
  "bugs": {
    "url": "https://github.com/schiste/Aexeo/issues"
  },
  "keywords": [
    "emdash",
    "emdash-plugin",
    "seo",
    "geo",
    "cms",
    "wasm",
    "cloudflare"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./configured": {
      "types": "./dist/configured.d.ts",
      "import": "./dist/configured.js",
      "default": "./dist/configured.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "import": "./dist/admin.js",
      "default": "./dist/admin.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox-entry.d.ts",
      "import": "./dist/sandbox-entry.js",
      "default": "./dist/sandbox-entry.js"
    }
  },
  "files": [
    "dist",
    "wasm",
    "INSTALL.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:bundle": "node scripts/build-bundle.mjs",
    "build": "npm run sync-version && npm run build:wasm && npm run build:ts && npm run build:bundle",
    "typecheck": "npm run sync-version && tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@emdash-cms/core": "*",
    "emdash": ">=0.7.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@emdash-cms/core": {
      "optional": true
    },
    "emdash": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "emdash": "^0.7.0",
    "esbuild": "^0.28.0",
    "react": "^19.2.5",
    "typescript": "^5.6.0"
  }
}
